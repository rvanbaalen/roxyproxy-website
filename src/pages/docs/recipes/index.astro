---
import DocsLayout from "../../../layouts/DocsLayout.astro";

const base = import.meta.env.BASE_URL;

const recipes = [
  { title: "Debug a Failing Webhook", href: `${base}docs/recipes/debug-webhook`, description: "Capture and inspect Stripe/Twilio webhook traffic to find why it fails" },
  { title: "Find Why My API Returns 422", href: `${base}docs/recipes/debug-422`, description: "Trace a 422 Unprocessable Entity response back to the validation error" },
  { title: "Capture All Traffic from iOS App", href: `${base}docs/recipes/ios-capture`, description: "Set up your iPhone to route traffic through RoxyProxy on your Mac" },
];
---

<DocsLayout title="Recipes" description="Step-by-step HTTP debugging recipes for RoxyProxy. Debug failing webhooks, trace 422 API errors, capture iOS app traffic, and use AI agents for automated debugging." headings={[
  { id: "related", text: "Related", depth: 2 },
]}>
  <div class="prose-custom">
    <p class="text-text-secondary mb-10">
      Step-by-step debugging workflows for common scenarios.
    </p>

    <div class="space-y-4">
      {recipes.map((r) => (
        <a href={r.href} class="block group border border-border rounded-lg p-4 hover:border-accent/40 transition-colors">
          <h2 class="text-text-primary font-semibold group-hover:text-accent transition-colors">{r.title}</h2>
          <p class="text-text-muted text-sm mt-0.5">{r.description}</p>
        </a>
      ))}
    </div>

    <div class="mt-10">
      <h2 id="related">Related</h2>
      <ul>
        <li><a href={`${base}docs/getting-started`}>Getting Started</a> - Install and capture your first request</li>
        <li><a href={`${base}docs/agent-plugin`}>AI Agent Plugin</a> - AI-assisted HTTP debugging in your terminal</li>
      </ul>
    </div>
  </div>
</DocsLayout>

<style>
  .prose-custom h2 {
    color: var(--color-text-primary);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .prose-custom ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-custom li {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }
  .prose-custom a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-custom a:hover {
    color: var(--color-text-primary);
  }
</style>
