---
import DocsLayout from "../../layouts/DocsLayout.astro";

const base = import.meta.env.BASE_URL;

const sections = [
  { title: "Getting Started", href: `${base}docs/getting-started`, description: "Install and capture your first request in 30 seconds" },
  { title: "CLI Reference", href: `${base}docs/cli`, description: "All commands, flags, and output formats" },
  { title: "Web UI", href: `${base}docs/web-ui`, description: "Live traffic stream, filters, and request inspection" },
  { title: "REST API", href: `${base}docs/api`, description: "Query captured traffic programmatically" },
  { title: "AI Agent Plugin", href: `${base}docs/agent-plugin`, description: "AI-assisted debugging workflows" },
  { title: "Configuration", href: `${base}docs/configuration`, description: "Config file, auto-cleanup, and storage options" },
  { title: "HTTPS Interception", href: `${base}docs/https`, description: "How MITM works, CA trust, and certificate details" },
  { title: "Architecture", href: `${base}docs/architecture`, description: "System design, data flow, and key decisions" },
  { title: "Recipes", href: `${base}docs/recipes`, description: "Step-by-step debugging workflows with and without AI" },
];
---

<DocsLayout title="Documentation" description="Complete documentation for Laurel Proxy, the open source HTTP/HTTPS intercepting proxy. Guides for CLI, Web UI, REST API, HTTPS interception, AI agent plugin, and debugging recipes." headings={[]}>
  <div class="prose-custom">
    <p class="text-text-secondary mb-10">
      Everything you need to capture, query, and debug HTTP traffic.
    </p>

    <div class="space-y-4">
      {sections.map((s) => (
        <a href={s.href} class="block group border border-border rounded-lg p-4 hover:border-accent/40 transition-colors">
          <h2 class="text-text-primary font-semibold group-hover:text-accent transition-colors">{s.title}</h2>
          <p class="text-text-muted text-sm mt-0.5">{s.description}</p>
        </a>
      ))}
    </div>
  </div>
</DocsLayout>
