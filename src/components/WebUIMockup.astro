---
// Web UI dashboard mockup showing traffic view with detail panel and repeater
---

<div class="rounded-lg border border-border overflow-hidden bg-[#111] text-[11px] font-mono">
  <!-- App header -->
  <div class="flex items-center justify-between px-3 py-2 bg-[#141414] border-b border-border">
    <div class="flex items-center gap-3">
      <span class="text-accent font-bold text-xs font-sans">RoxyProxy</span>
      <span class="inline-flex items-center gap-1 text-accent text-[10px] bg-accent/10 px-1.5 py-0.5 rounded-full border border-accent/20">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        Live
      </span>
      <span class="text-text-muted text-[10px]">Port 8080 &middot; 847 requests &middot; DB 3.9MB</span>
    </div>
    <div class="flex gap-1.5">
      <span class="px-2 py-0.5 rounded text-[10px] border border-border text-text-muted">Clear</span>
      <span class="px-2 py-0.5 rounded text-[10px] border border-red-500/50 text-red-400">Stop</span>
    </div>
  </div>

  <!-- Tab bar: Traffic / Repeater -->
  <div class="flex border-b border-border bg-[#111]">
    <span class="px-4 py-1.5 text-accent text-[11px] font-sans font-medium border-b-2 border-accent">Traffic</span>
    <span class="px-4 py-1.5 text-text-muted text-[11px] font-sans">Repeater</span>
  </div>

  <!-- Filter bar -->
  <div class="flex gap-1.5 px-3 py-1.5 border-b border-border bg-[#111]">
    <div class="bg-[#1a1a1a] border border-border rounded px-2 py-1 text-accent flex-1">api.example.com</div>
    <div class="bg-[#1a1a1a] border border-border rounded px-2 py-1 text-text-muted w-16">Status</div>
    <div class="bg-[#1a1a1a] border border-border rounded px-2 py-1 text-text-muted w-20">All Methods</div>
    <div class="bg-[#1a1a1a] border border-border rounded px-2 py-1 text-text-muted flex-1">Search URL...</div>
  </div>

  <!-- Traffic table + detail panel -->
  <div class="flex" style="height: 220px;">
    <!-- Table -->
    <div class="flex-1 overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="bg-[#1a1a1a]">
            <th class="text-left px-2 py-1.5 text-text-muted font-medium border-b border-border">Time <span class="text-accent">↓</span></th>
            <th class="text-left px-2 py-1.5 text-text-muted font-medium border-b border-border">Method</th>
            <th class="text-left px-2 py-1.5 text-text-muted font-medium border-b border-border">Path</th>
            <th class="text-left px-2 py-1.5 text-text-muted font-medium border-b border-border">Status</th>
            <th class="text-left px-2 py-1.5 text-text-muted font-medium border-b border-border">Duration</th>
            <th class="text-left px-2 py-1.5 text-text-muted font-medium border-b border-border hidden lg:table-cell">Size</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-[#1a1a1a]">
            <td class="px-2 py-1 text-text-muted">14:23:01</td>
            <td class="px-2 py-1 text-green-400 font-semibold">GET</td>
            <td class="px-2 py-1 text-text-secondary">/v2/users/me</td>
            <td class="px-2 py-1 text-green-400">200</td>
            <td class="px-2 py-1 text-text-muted">34ms</td>
            <td class="px-2 py-1 text-text-muted hidden lg:table-cell">1.2K</td>
          </tr>
          <tr class="border-b border-[#1a1a1a] bg-accent/[0.06]">
            <td class="px-2 py-1 text-text-muted">14:23:02</td>
            <td class="px-2 py-1 text-blue-400 font-semibold">POST</td>
            <td class="px-2 py-1 text-text-secondary">/v2/orders</td>
            <td class="px-2 py-1 text-amber-400">422</td>
            <td class="px-2 py-1 text-text-muted">89ms</td>
            <td class="px-2 py-1 text-text-muted hidden lg:table-cell">342B</td>
          </tr>
          <tr class="border-b border-[#1a1a1a]">
            <td class="px-2 py-1 text-text-muted">14:23:02</td>
            <td class="px-2 py-1 text-green-400 font-semibold">GET</td>
            <td class="px-2 py-1 text-text-secondary">/v2/products?page=1</td>
            <td class="px-2 py-1 text-green-400">200</td>
            <td class="px-2 py-1 text-text-muted">156ms</td>
            <td class="px-2 py-1 text-text-muted hidden lg:table-cell">8.4K</td>
          </tr>
          <tr class="border-b border-[#1a1a1a]">
            <td class="px-2 py-1 text-text-muted">14:23:03</td>
            <td class="px-2 py-1 text-amber-400 font-semibold">PUT</td>
            <td class="px-2 py-1 text-text-secondary">/v2/cart/items/847</td>
            <td class="px-2 py-1 text-green-400">200</td>
            <td class="px-2 py-1 text-text-muted">67ms</td>
            <td class="px-2 py-1 text-text-muted hidden lg:table-cell">512B</td>
          </tr>
          <tr class="border-b border-[#1a1a1a]">
            <td class="px-2 py-1 text-text-muted">14:23:04</td>
            <td class="px-2 py-1 text-green-400 font-semibold">GET</td>
            <td class="px-2 py-1 text-text-secondary">/v2/notifications</td>
            <td class="px-2 py-1 text-green-400">200</td>
            <td class="px-2 py-1 text-text-muted">45ms</td>
            <td class="px-2 py-1 text-text-muted hidden lg:table-cell">2.1K</td>
          </tr>
          <tr class="border-b border-[#1a1a1a]">
            <td class="px-2 py-1 text-text-muted">14:23:06</td>
            <td class="px-2 py-1 text-red-400 font-semibold">DELETE</td>
            <td class="px-2 py-1 text-text-secondary">/v2/cart/items/312</td>
            <td class="px-2 py-1 text-green-400">204</td>
            <td class="px-2 py-1 text-text-muted">41ms</td>
            <td class="px-2 py-1 text-text-muted hidden lg:table-cell">0B</td>
          </tr>
          <tr class="border-b border-[#1a1a1a]">
            <td class="px-2 py-1 text-text-muted">14:23:08</td>
            <td class="px-2 py-1 text-green-400 font-semibold">GET</td>
            <td class="px-2 py-1 text-text-secondary">/v2/products/featured</td>
            <td class="px-2 py-1 text-red-400">500</td>
            <td class="px-2 py-1 text-text-muted">2.1s</td>
            <td class="px-2 py-1 text-text-muted hidden lg:table-cell">184B</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Detail panel -->
    <div class="w-[220px] border-l border-border bg-[#0d0d0d] overflow-hidden shrink-0 hidden md:block">
      <div class="px-3 py-2 border-b border-border flex items-center justify-between">
        <span class="text-text-primary font-sans text-[11px] font-semibold">POST /v2/orders</span>
        <span class="text-amber-400 text-[10px]">422</span>
      </div>
      <div class="flex border-b border-border">
        <span class="px-2 py-1 text-accent border-b border-accent text-[10px]">Headers</span>
        <span class="px-2 py-1 text-text-muted text-[10px]">Body</span>
        <span class="px-2 py-1 text-text-muted text-[10px]">Response</span>
        <span class="px-2 py-1 text-blue-400 text-[10px] ml-auto">Replay &rarr;</span>
      </div>
      <div class="px-3 py-2 text-[10px] leading-relaxed">
        <div><span class="text-accent">Host:</span> <span class="text-text-secondary">api.example.com</span></div>
        <div><span class="text-accent">Content-Type:</span> <span class="text-text-secondary">application/json</span></div>
        <div><span class="text-accent">Authorization:</span> <span class="text-text-secondary">Bearer eyJ...</span></div>
        <div class="mt-2 text-text-muted">Response Body</div>
        <div class="mt-1 text-text-secondary">
          <div>{"{"}</div>
          <div>&nbsp;&nbsp;"error": "<span class="text-amber-400">validation_failed</span>",</div>
          <div>&nbsp;&nbsp;"details": [{"{"}</div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;"field": "<span class="text-amber-400">quantity</span>",</div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;"msg": "<span class="text-red-400">must be &gt; 0</span>"</div>
          <div>&nbsp;&nbsp;{"}"}]</div>
          <div>{"}"}</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="flex gap-4 px-3 py-1.5 border-t border-border bg-[#141414] text-[10px] text-text-muted font-sans">
    <span>Requests: <span class="text-text-secondary">847</span></span>
    <span>Filtered: <span class="text-text-secondary">10</span></span>
    <span>Avg: <span class="text-text-secondary">67ms</span></span>
    <span>Errors: <span class="text-red-400">2</span></span>
  </div>
</div>
