---
const base = import.meta.env.BASE_URL;

const codeExamples = [
  {
    title: "Query traffic",
    content: 'curl "http://127.0.0.1:8081/api/requests?status=500&amp;limit=5"\n<span class="text-text-muted"># → 3 matching requests with full headers and bodies</span>',
  },
  {
    title: "Replay a request",
    content: 'curl -X POST http://127.0.0.1:8081/api/replay \\\n  -H "Content-Type: application/json" \\\n  -d \'{"id": "a1b2c3d4..."}\'\n<span class="text-text-muted"># → 200 OK</span>',
  },
  {
    title: "Stream live events",
    content: 'curl -N http://127.0.0.1:8081/api/events\n<span class="text-text-muted"># event: request\n# data: {"method":"POST","status":422,...}</span>',
  },
  {
    title: "Check proxy status",
    content: 'curl http://127.0.0.1:8081/api/status\n<span class="text-text-muted"># → {"running": true, "requestCount": 142}</span>',
  },
];

const useCases = [
  {
    title: "AI Agent Debugging",
    description: "Your agent queries the API, finds the broken request, reads the validation error, fixes your code, replays to verify. You watch.",
  },
  {
    title: "CI Pipeline Integration",
    description: "Run your test suite with traffic routed through the proxy. Then query for unexpected 500s, slow requests, or missing headers.",
  },
  {
    title: "Custom Dashboards",
    description: "Build your own traffic visualization using the same REST API that powers the built-in dashboard. Stream events via SSE for real-time updates.",
  },
];
---

<section class="px-6 md:px-12 py-16 md:py-24 border-t border-border">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-10">
      <div class="text-accent text-xs uppercase tracking-[2px] mb-3 font-medium">For scripts, agents, and pipelines</div>
      <h2 class="text-text-primary text-2xl md:text-3xl font-bold tracking-tight mb-3">
        Programmable by design
      </h2>
      <p class="text-text-secondary max-w-2xl mx-auto">
        Every captured request is available through a REST API. Query traffic, replay requests, stream events in real-time. Build on top of Laurel Proxy with curl, scripts, or your AI agent.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-4 mb-10">
      {codeExamples.map((example) => (
        <div class="rounded-lg border border-border bg-bg-secondary overflow-hidden">
          <div class="px-4 py-2 border-b border-border">
            <span class="text-text-primary text-sm font-medium">{example.title}</span>
          </div>
          <pre class="px-4 py-3 font-mono text-[13px] leading-relaxed overflow-x-auto text-text-secondary" set:html={example.content} />
        </div>
      ))}
    </div>

    <div class="grid md:grid-cols-3 gap-5 mb-8">
      {useCases.map((useCase) => (
        <div class="rounded-lg border border-border bg-bg-secondary p-6">
          <h3 class="text-text-primary font-semibold text-base mb-2">{useCase.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{useCase.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center">
      <a
        href={`${base}docs/api/`}
        class="text-accent hover:text-accent-dim text-sm font-medium transition-colors"
      >
        Read docs: REST API &rarr;
      </a>
    </div>
  </div>
</section>
