---
const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-border px-6 md:px-12 py-8 text-text-muted text-sm" role="contentinfo">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <a href={`${base}docs/`} class="hover:text-text-primary transition-colors">Docs</a>
      <span class="text-border hidden md:inline">·</span>
      <a href={`${base}docs/getting-started/`} class="hover:text-text-primary transition-colors">Getting Started</a>
      <span class="text-border hidden md:inline">·</span>
      <a href={`${base}docs/cli/`} class="hover:text-text-primary transition-colors">CLI Reference</a>
      <span class="text-border hidden md:inline">·</span>
      <a href={`${base}docs/api/`} class="hover:text-text-primary transition-colors">API</a>
      <span class="text-border hidden md:inline">·</span>
      <a href={`${base}docs/recipes/`} class="hover:text-text-primary transition-colors">Recipes</a>
    </div>
    <div class="flex items-center gap-4">
      <a href="https://github.com/rvanbaalen/roxyproxy" target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors">GitHub</a>
      <span class="text-border">·</span>
      <a href="https://www.npmjs.com/package/@rvanbaalen/roxyproxy" target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors">npm</a>
    </div>
  </div>
  <div class="mt-4 pt-4 border-t border-border">
    <p>RoxyProxy · MIT License · Made by <a href="https://robinvanbaalen.nl" class="hover:text-text-primary transition-colors">Robin</a></p>
  </div>
</footer>
